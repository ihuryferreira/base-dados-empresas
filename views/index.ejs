<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="shortcut icon" href="/img/favicon2.png" type="image/x-icon">
  <link rel="icon" sizes="32x32" href="/img/favicon2.png">
  <link rel="apple-touch-icon" href="/img/favicon2.png">
  <title>Empresas</title>

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- CSS -->
  <link rel="stylesheet" href="/styles/main.css">
</head>

<body class="bg-gray-100 font-sans flex flex-col min-h-screen">

  <!-- TÍTULO -->
  <h1 class="text-3xl font-bold mt-6 text-center hero-title bloquear-selecao-text">
    Lista de Empresas
  </h1>

  <!-- CONTAINER -->
  <div class="w-full max-w-6xl px-4 mx-auto">

    <!-- FORMULÁRIO -->
    <form action="/buscar" method="get" class="flex gap-4 flex-wrap justify-center mt-6">

      <input 
        type="text" 
        name="q" 
        placeholder="Nome ou CNPJ"
        class="border p-2 rounded focus:outline-none focus:ring-2 focus:ring-blue-400"
      />

      <select name="municipio" class="border p-2 rounded">
        <option value="">Todos Municípios</option>
        <option value="GOIANIA">GOIANIA</option>
        <option value="SAO PAULO">SAO PAULO</option>
        <option value="BRASILIA">BRASILIA</option>
      </select>

      <select name="uf" class="border p-2 rounded">
        <option value="">Todas UFs</option>
        <option value="GO">GO</option>
        <option value="SP">SP</option>
        <option value="DF">DF</option>
      </select>

      <button type="submit" class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 transition">
        Buscar
      </button>

      <a href="/" class="bg-gray-500 text-white px-4 py-2 rounded flex items-center hover:bg-gray-600 transition">
        Limpar
      </a>

    </form>

    <!-- TABELA -->
    <div class="bg-white rounded-lg shadow overflow-x-auto mt-6 mb-10">
      
      <table class="w-full text-sm text-left border">

        <thead class="bg-gray-800 text-white">
          <tr>
            <th class="px-4 py-3">CNPJ</th>
            <th class="px-4 py-3">Nome</th>
            <th class="px-4 py-3">Email</th>
            <th class="px-4 py-3">Telefone</th>
            <th class="px-4 py-3">Instagram</th>
            <th class="px-4 py-3">Situação</th>
            <th class="px-4 py-3">Município</th>
            <th class="px-4 py-3">UF</th>
          </tr>
        </thead>

        <tbody class="divide-y">

          <% if (empresas.length === 0) { %>
            <tr>
              <td colspan="8" class="text-center py-6 text-gray-500">
                Nenhuma empresa encontrada
              </td>
            </tr>
          <% } %>

          <% empresas.forEach(emp => { %>
            <tr class="hover:bg-gray-100 transition">
              <td class="px-4 py-2"><%= emp.cnpj ? emp.cnpj : '-' %></td>
              <td class="px-4 py-2 font-semibold"><%= emp.nome ? emp.nome : '-' %></td>
              <td class="px-4 py-2"><%= emp.email ? emp.email : '-' %></td>
              <td class="px-4 py-2"><%= emp.telefone ? emp.telefone : '-' %></td>
              <td class="px-4 py-2"><%= emp.instagram ? emp.instagram : '-' %></td>
              <td class="px-4 py-2"><%= emp.situacao ? emp.situacao : '-' %></td>
              <td class="px-4 py-2"><%= emp.municipio ? emp.municipio : '-' %></td>
              <td class="px-4 py-2 font-bold"><%= emp.uf ? emp.uf : '-' %></td>
            </tr>
          <% }) %>

        </tbody>

      </table>

    </div>

  </div>

  <!-- FOOTER -->
  <footer class="bg-gray-900 text-gray-400 py-8 px-4 mt-auto w-full">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">

      <div class="text-white font-bold text-xl">
        CaptarEmpresas<span class="text-blue-500">.</span>
      </div>

      <div class="text-sm text-center md:text-right">
        <div>&copy; <%= new Date().getFullYear() %> CaptarEmpresas Corp. Todos os direitos reservados.</div>
        <div class="text-xs text-gray-500 mt-1">
          Desenvolvido por 
          <a href="SEU_LINK_DO_GITHUB_OU_PORTFOLIO" target="_blank" class="text-blue-400 hover:underline">
            Ihury Ferreira
          </a>
        </div>
      </div>

    </div>
  </footer>

</body>
</html>