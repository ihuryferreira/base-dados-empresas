<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Empresas</title>

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 font-sans p-6">

  <h1 class="text-2xl font-bold mb-4">Lista de Empresas</h1>

  <div class="bg-white rounded-lg shadow overflow-x-auto">
    
    <table class="w-full text-sm text-left">

      <!-- Cabeçalho -->
      <thead class="bg-gray-800 text-white">
        <tr>
          <th class="px-4 py-3">CNPJ</th>
          <th class="px-4 py-3">Nome</th>
          <th class="px-4 py-3">Email</th>
          <th class="px-4 py-3">Telefone</th>
          <th class="px-4 py-3">Município</th>
          <th class="px-4 py-3">UF</th>
        </tr>
      </thead>

      <!-- Corpo -->
      <tbody class="divide-y">

        <% if (empresas.length === 0) { %>
          <tr>
            <td colspan="6" class="text-center py-6 text-gray-500">
              Nenhuma empresa encontrada
            </td>
          </tr>
        <% } %>

        <% empresas.forEach(emp => { %>
          <tr class="hover:bg-gray-100">
            <td class="px-4 py-2"><%= emp.cnpj || '-' %></td>
            <td class="px-4 py-2 font-semibold"><%= emp.nome || '-' %></td>
            <td class="px-4 py-2"><%= emp.email || '-' %></td>
            <td class="px-4 py-2"><%= emp.telefone || '-' %></td>
            <td class="px-4 py-2"><%= emp.municipio || '-' %></td>
            <td class="px-4 py-2 font-bold"><%= emp.uf || '-' %></td>
          </tr>
        <% }) %>

      </tbody>
    </table>

  </div>

</body>
</html>