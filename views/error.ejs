<!DOCTYPE html>
<html>
<head>
  <title>Erro</title>
  <style>
    body {
      font-family: Arial;
      background: #f4f4f4;
      text-align: center;
      padding-top: 100px;
    }

    h1 {
      font-size: 40px;
      color: #e74c3c;
    }

    p {
      font-size: 18px;
      color: #555;
    }

    a {
      display: inline-block;
      margin-top: 20px;
      padding: 10px 15px;
      background: #007bff;
      color: white;
      text-decoration: none;
      border-radius: 5px;
    }
  </style>
</head>
<body>

  <h1>⚠ Ocorreu um erro</h1>
  <p><%= message %></p>

  <a href="/">Voltar</a>

</body>
</html>